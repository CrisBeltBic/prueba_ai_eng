# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: groq | openai | anthropic | ollama
LLM_PROVIDER=groq

# Groq (default — free tier)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI (optional)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama local (optional — no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# ── Vector Database ────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── Embeddings ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2

# ── Ingestion ──────────────────────────────────────────────────────────────────
SCRAPER_START_URL=https://www.bancolombia.com/personas
SCRAPER_MAX_PAGES=200
SCRAPER_DELAY_SECONDS=1.0

# ── Inter-service URLs ─────────────────────────────────────────────────────────
CHAT_SERVICE_URL=http://chat_service:8082
AGENT_SERVICE_URL=http://agent_service:8080
