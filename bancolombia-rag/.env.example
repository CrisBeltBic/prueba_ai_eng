# Security — shared key between frontend and agent_service
# Leave empty to disable auth (useful for local dev without Docker)
AGENT_API_SERVICE_KEY=change-me-before-deploy

# LLM Provider
# Options: groq | ollama | etc
LLM_PROVIDER=groq

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile


# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# Vector Store Provider
# Options: chroma | qdrant | pinecone
VECTOR_STORE_PROVIDER=chroma

# ChromaDB (default)
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Embeddings
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2

# Ingestion
SCRAPER_START_URL=https://www.bancolombia.com/personas
SCRAPER_MAX_PAGES=200
SCRAPER_DELAY_SECONDS=1.0

# PostgreSQL (chat_service)
DATABASE_URL=postgresql://chat_user:chat_password@postgres:5432/chat_db

# Inter-service URLs
CHAT_SERVICE_URL=http://chat_service:8082
AGENT_SERVICE_URL=http://agent_service:8080
VECTOR_STORE_SERVICE_URL=http://vector_store_service:8084
SCRAPER_SERVICE_URL=http://scraper_service:8083
